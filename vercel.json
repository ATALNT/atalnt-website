{
  "crons": [
    {
      "path": "/api/instantly/cron-health-score",
      "schedule": "0 0,8,16 * * *"
    },
    {
      "path": "/api/instantly/cron-reply-manager",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/instantly/cron-lead-responder",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/instantly/cron-prune-leads",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/instantly/cron-bounce-guard",
      "schedule": "0 */2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
