{
  "crons": [
    {
      "path": "/api/instantly/cron?task=health",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/instantly/cron?task=prune",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/instantly/cron?task=bounce",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
